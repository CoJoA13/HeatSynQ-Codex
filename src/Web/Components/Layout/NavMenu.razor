@using Microsoft.AspNetCore.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IAuthorizationService AuthorizationService

<div class="brand-row"><a class="brand" href=""><span class="brand-mark">H</span><span>HeatSynQ</span></a></div>
<input type="checkbox" title="Navigation menu" class="navbar-toggler" />
<div class="nav-scrollable">
    <nav class="nav flex-column">
        <NavLink class="home-link" href="" Match="NavLinkMatch.All">&#8962; <span>Home</span></NavLink>
        <details><summary>Sales &amp; Customer Service</summary><span class="coming-soon">Available in Module 2</span></details>
        <details><summary>Process Engineering</summary><span class="coming-soon">Available in Module 2</span></details>
        <details><summary>Order Intake</summary><span class="coming-soon">Available in Module 4</span></details>
        <details><summary>Planning &amp; Production</summary><span class="coming-soon">Available in Modules 5&ndash;6</span></details>
        <details><summary>Quality &amp; Compliance</summary><span class="coming-soon">Available in Module 7</span></details>
        <details><summary>Supply Chain</summary><span class="coming-soon">Available in Module 8</span></details>
        <details><summary>Shipping &amp; Billing</summary><span class="coming-soon">Available in Modules 9&ndash;10</span></details>
        <details><summary>Reports &amp; Analytics</summary><span class="coming-soon">Available in Module 11</span></details>
        @if (CanSeeAdministration)
        {
            <details open class="admin-group">
                <summary>Administration</summary>
                <AuthorizeView Policy="platform.users.view"><NavLink href="admin/users">Users &amp; sessions</NavLink></AuthorizeView>
                <AuthorizeView Policy="platform.roles.view"><NavLink href="admin/roles">Roles &amp; permissions</NavLink></AuthorizeView>
                <AuthorizeView Policy="platform.settings.view"><NavLink href="admin/facility">Company &amp; facility</NavLink></AuthorizeView>
                <AuthorizeView Policy="platform.audit.view"><NavLink href="admin/audit">Audit history</NavLink></AuthorizeView>
                <AuthorizeView Policy="platform.health.view"><NavLink href="admin/system">System health</NavLink></AuthorizeView>
            </details>
        }
    </nav>
</div>

@code {
    private bool CanSeeAdministration { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var user = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        var policies = new[]
        {
            "platform.users.view",
            "platform.roles.view",
            "platform.settings.view",
            "platform.audit.view",
            "platform.health.view"
        };
        foreach (var policy in policies)
        {
            if ((await AuthorizationService.AuthorizeAsync(user, policy)).Succeeded)
            {
                CanSeeAdministration = true;
                break;
            }
        }
    }
}
