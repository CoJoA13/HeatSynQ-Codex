@page "/admin/roles"
@using HeatSynQ.Platform.Domain.Security
@using HeatSynQ.Platform.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Policy = "platform.roles.view")]
@inject IDbContextFactory<PlatformDbContext> DbContextFactory

<PageTitle>Roles &amp; permissions | HeatSynQ</PageTitle>
<div class="page-heading">
    <div>
        <div class="eyebrow">ADMINISTRATION / SECURITY</div>
        <h1>Roles &amp; permissions</h1>
        <p>Role templates provide defaults; user overrides handle documented exceptions.</p>
    </div>
    <button class="primary-action" type="button" data-dialog-open="add-role-dialog">+ Add role</button>
</div>
<div class="role-layout">
    <section class="panel role-list">
        <h2>Role templates</h2>
        @foreach (var role in RoleRows)
        {
            <a class="role @(SelectedRole?.Id == role.Id ? "selected" : null)"
               href="/admin/roles?role=@role.Id">
                <b>@role.Name</b>
                <small>@role.Description</small>
                <small>@role.UserCount user@(role.UserCount == 1 ? null : "s") · @role.PermissionKeys.Length grants</small>
            </a>
        }
    </section>
    <section class="panel permission-panel">
        @if (SelectedRole is not null)
        {
            <form action="/api/v1/platform/roles/@SelectedRole.Id/permissions"
                  method="post"
                  data-api-form="update-role"
                  data-api-method="PUT">
                <div class="panel-heading">
                    <div>
                        <h2>@SelectedRole.Name</h2>
                        <p>@(SelectedRole.IsSystemRole ? "System role" : "Custom role") · changes require a reason</p>
                    </div>
                    <button type="submit" class="primary-action" disabled="@SelectedRole.IsSystemRole">Save changes</button>
                </div>
                <div class="form-error" role="alert" hidden></div>
                @foreach (var module in PlatformPermissionCatalog.All.GroupBy(x => x.Module))
                {
                    <h3>@module.Key</h3>
                    @foreach (var permission in module)
                    {
                        <label class="permission-row">
                            <input type="checkbox"
                                   name="PermissionKeys"
                                   value="@permission.Key"
                                   checked="@SelectedRole.PermissionKeys.Contains(permission.Key)"
                                   disabled="@SelectedRole.IsSystemRole" />
                            <span>
                                <b>@permission.Key</b>
                                <small>@permission.Action — @permission.Description</small>
                            </span>
                        </label>
                    }
                }
                @if (!SelectedRole.IsSystemRole)
                {
                    <label class="reason-field">
                        <span>Reason for change</span>
                        <textarea name="Reason" rows="3" required></textarea>
                    </label>
                }
            </form>
        }
    </section>
</div>

<dialog id="add-role-dialog" class="admin-dialog">
    <form action="/api/v1/platform/roles" method="post" data-api-form="create-role">
        <div class="dialog-heading">
            <div>
                <div class="eyebrow">ADMINISTRATION / ROLES</div>
                <h2>Add role</h2>
            </div>
            <button type="button" class="dialog-close" data-dialog-close aria-label="Close">×</button>
        </div>
        <div class="form-error" role="alert" hidden></div>
        <div class="form-grid">
            <label>
                <span>Name</span>
                <input name="Name" required />
            </label>
            <label>
                <span>Description</span>
                <input name="Description" required />
            </label>
        </div>
        <fieldset>
            <legend>Permission grants</legend>
            @foreach (var permission in PlatformPermissionCatalog.All)
            {
                <label class="permission-row">
                    <input type="checkbox" name="PermissionKeys" value="@permission.Key" />
                    <span>
                        <b>@permission.Key</b>
                        <small>@permission.Action — @permission.Description</small>
                    </span>
                </label>
            }
        </fieldset>
        <label>
            <span>Reason</span>
            <textarea name="Reason" rows="3" required
                      placeholder="Why is this role being created?"></textarea>
        </label>
        <div class="dialog-actions">
            <button type="button" data-dialog-close>Cancel</button>
            <button type="submit" class="primary-action">Create role</button>
        </div>
    </form>
</dialog>

@code {
    [SupplyParameterFromQuery(Name = "role")]
    public Guid? SelectedRoleId { get; set; }

    private RoleRow[] RoleRows { get; set; } = [];
    private RoleRow? SelectedRole { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        var roles = await db.Roles
            .AsNoTracking()
            .OrderByDescending(x => x.IsSystemRole)
            .ThenBy(x => x.Name)
            .ToArrayAsync();
        var grants = await db.RolePermissions
            .AsNoTracking()
            .OrderBy(x => x.PermissionKey)
            .ToArrayAsync();
        var userCounts = await db.UserRoles
            .AsNoTracking()
            .GroupBy(x => x.RoleId)
            .Select(x => new { RoleId = x.Key, Count = x.Count() })
            .ToDictionaryAsync(x => x.RoleId, x => x.Count);

        RoleRows = roles.Select(role => new RoleRow(
                role.Id,
                role.Name ?? string.Empty,
                role.Description,
                role.IsSystemRole,
                userCounts.GetValueOrDefault(role.Id),
                grants
                    .Where(x => x.RoleId == role.Id)
                    .Select(x => x.PermissionKey)
                    .ToArray()))
            .ToArray();
        SelectedRole = RoleRows.SingleOrDefault(x => x.Id == SelectedRoleId)
            ?? RoleRows.FirstOrDefault();
    }

    private sealed record RoleRow(
        Guid Id,
        string Name,
        string Description,
        bool IsSystemRole,
        int UserCount,
        string[] PermissionKeys);
}
