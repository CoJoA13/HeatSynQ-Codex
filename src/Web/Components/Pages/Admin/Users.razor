@page "/admin/users"
@using HeatSynQ.Platform.Domain.Security
@using HeatSynQ.Platform.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@attribute [Authorize(Policy = "platform.users.view")]
@inject IDbContextFactory<PlatformDbContext> DbContextFactory
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Users &amp; sessions | HeatSynQ</PageTitle>
<div class="page-heading">
    <div>
        <div class="eyebrow">ADMINISTRATION / SECURITY</div>
        <h1>Users &amp; sessions</h1>
        <p>Manage ERP identities, account status, role membership, and active sessions.</p>
    </div>
    <AuthorizeView Policy="platform.users.edit">
        <button class="primary-action" type="button" data-dialog-open="add-user-dialog">+ Add user</button>
    </AuthorizeView>
</div>
<section class="panel data-panel">
    <div class="table-tools">
        <input placeholder="Search users…" aria-label="Search users" />
        <button>Filters</button>
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th>User</th>
                <th>Username</th>
                <th>Roles</th>
                <th>Overrides</th>
                <th>MFA</th>
                <th>Status</th>
                <th>Last activity</th>
                <th><span class="visually-hidden">Actions</span></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in UserRows)
            {
                <tr>
                    <td><b>@user.DisplayName</b></td>
                    <td>@user.Username</td>
                    <td>
                        @if (user.Roles.Length == 0)
                        {
                            <span class="muted">No roles</span>
                        }
                        else
                        {
                            @foreach (var role in user.Roles)
                            {
                                <span class="pill">@role</span>
                            }
                        }
                    </td>
                    <td>
                        @if (user.Overrides.Length == 0)
                        {
                            <span class="muted">None</span>
                        }
                        else
                        {
                            @foreach (var permissionOverride in user.Overrides)
                            {
                                @if (CanOverridePermissions)
                                {
                                <button class="override-chip @(permissionOverride.IsAllowed ? "allow" : "deny")"
                                        type="button"
                                        data-dialog-open="override-@permissionOverride.Id">
                                    @(permissionOverride.IsAllowed ? "Allow" : "Deny") · @permissionOverride.PermissionKey
                                </button>
                                <dialog id="override-@permissionOverride.Id" class="admin-dialog compact-dialog">
                                    <form action="/api/v1/platform/users/@user.Id/permission-overrides/@permissionOverride.Id"
                                          method="post"
                                          data-api-form="revoke-permission-override"
                                          data-api-method="DELETE">
                                        <div class="dialog-heading">
                                            <div>
                                                <div class="eyebrow">ADMINISTRATION / PERMISSIONS</div>
                                                <h2>Revoke override</h2>
                                            </div>
                                            <button type="button" class="dialog-close" data-dialog-close aria-label="Close">×</button>
                                        </div>
                                        <dl class="override-summary">
                                            <dt>User</dt>
                                            <dd>@user.DisplayName</dd>
                                            <dt>Permission</dt>
                                            <dd>@permissionOverride.PermissionKey</dd>
                                            <dt>Effect</dt>
                                            <dd>@(permissionOverride.IsAllowed ? "Allow" : "Deny")</dd>
                                            <dt>Expires</dt>
                                            <dd>@(permissionOverride.ExpiresAt?.ToLocalTime().ToString("g") ?? "No expiration")</dd>
                                        </dl>
                                        <div class="form-error" role="alert" hidden></div>
                                        <label>
                                            <span>Reason</span>
                                            <textarea name="Reason" rows="3" required></textarea>
                                        </label>
                                        <div class="dialog-actions">
                                            <button type="button" data-dialog-close>Cancel</button>
                                            <button type="submit" class="primary-action">Revoke override</button>
                                        </div>
                                    </form>
                                </dialog>
                                }
                                else
                                {
                                    <span class="pill">@permissionOverride.PermissionKey</span>
                                }
                            }
                        }
                    </td>
                    <td>Optional</td>
                    <td>
                        <span class="state @(user.IsEnabled ? "active" : "inactive")">
                            @(user.IsEnabled ? "Active" : "Disabled")
                        </span>
                    </td>
                    <td>@(user.LastSeenAt?.ToLocalTime().ToString("g") ?? "—")</td>
                    <td>
                        <div class="row-actions">
                            @if (CanEditUsers)
                            {
                            <button class="row-action"
                                    type="button"
                                    data-dialog-open="status-@user.Id">
                                @(user.IsEnabled ? "Disable" : "Restore")
                            </button>
                            @if (!user.HasSystemRole || CanEditRoles)
                            {
                            <button class="row-action"
                                    type="button"
                                    data-dialog-open="password-@user.Id">
                                Reset password
                            </button>
                            }
                            }
                            @if (CanEditUsers && CanEditRoles)
                            {
                            <button class="row-action"
                                    type="button"
                                    data-dialog-open="roles-@user.Id">
                                Edit roles
                            </button>
                            }
                            @if (CanRevokeSessions)
                            {
                            <button class="row-action"
                                    type="button"
                                    data-dialog-open="sessions-@user.Id">
                                Revoke sessions
                            </button>
                            }
                            @if (CanOverridePermissions)
                            {
                            <button class="row-action"
                                    type="button"
                                    data-dialog-open="permission-@user.Id">
                                Add override
                            </button>
                            }
                        </div>
                        @if (CanEditUsers)
                        {
                        <dialog id="status-@user.Id" class="admin-dialog compact-dialog">
                            <form action="/api/v1/platform/users/@user.Id/status"
                                  method="post"
                                  data-api-form="change-user-status"
                                  data-api-method="PUT">
                                <div class="dialog-heading">
                                    <div>
                                        <div class="eyebrow">ADMINISTRATION / USERS</div>
                                        <h2>@(user.IsEnabled ? "Disable" : "Restore") @user.DisplayName</h2>
                                    </div>
                                    <button type="button" class="dialog-close" data-dialog-close aria-label="Close">×</button>
                                </div>
                                <div class="form-error" role="alert" hidden></div>
                                <input type="hidden" name="IsEnabled" value="@(user.IsEnabled ? "false" : "true")" />
                                <label>
                                    <span>Reason</span>
                                    <textarea name="Reason" rows="3" required></textarea>
                                </label>
                                <div class="dialog-actions">
                                    <button type="button" data-dialog-close>Cancel</button>
                                    <button type="submit" class="primary-action">
                                        @(user.IsEnabled ? "Disable user" : "Restore user")
                                    </button>
                                </div>
                            </form>
                        </dialog>
                        @if (!user.HasSystemRole || CanEditRoles)
                        {
                        <dialog id="password-@user.Id" class="admin-dialog compact-dialog">
                            <form action="/api/v1/platform/users/@user.Id/reset-password"
                                  method="post"
                                  data-api-form="reset-user-password">
                                <div class="dialog-heading">
                                    <div>
                                        <div class="eyebrow">ADMINISTRATION / USERS</div>
                                        <h2>Reset password for @user.DisplayName</h2>
                                    </div>
                                    <button type="button" class="dialog-close" data-dialog-close aria-label="Close">Ã—</button>
                                </div>
                                <p>All active sessions will be revoked. The user must replace this temporary password after signing in.</p>
                                <div class="form-error" role="alert" hidden></div>
                                <label>
                                    <span>Temporary password</span>
                                    <input name="TemporaryPassword" type="password" autocomplete="new-password" minlength="12" required />
                                </label>
                                <label>
                                    <span>Reason</span>
                                    <textarea name="Reason" rows="3" required></textarea>
                                </label>
                                <div class="dialog-actions">
                                    <button type="button" data-dialog-close>Cancel</button>
                                    <button type="submit" class="primary-action">Reset password</button>
                                </div>
                            </form>
                        </dialog>
                        }
                        }
                        @if (CanRevokeSessions)
                        {
                        <dialog id="sessions-@user.Id" class="admin-dialog compact-dialog">
                            <form action="/api/v1/platform/users/@user.Id/revoke-sessions"
                                  method="post"
                                  data-api-form="revoke-user-sessions">
                                <div class="dialog-heading">
                                    <div>
                                        <div class="eyebrow">ADMINISTRATION / SESSIONS</div>
                                        <h2>Revoke sessions for @user.DisplayName</h2>
                                    </div>
                                    <button type="button" class="dialog-close" data-dialog-close aria-label="Close">×</button>
                                </div>
                                <p>This immediately signs the user out on every workstation and browser.</p>
                                <div class="form-error" role="alert" hidden></div>
                                <label>
                                    <span>Reason</span>
                                    <textarea name="Reason" rows="3" required></textarea>
                                </label>
                                <div class="dialog-actions">
                                    <button type="button" data-dialog-close>Cancel</button>
                                    <button type="submit" class="primary-action">Revoke sessions</button>
                                </div>
                            </form>
                        </dialog>
                        }
                        @if (CanEditUsers && CanEditRoles)
                        {
                        <dialog id="roles-@user.Id" class="admin-dialog compact-dialog">
                            <form action="/api/v1/platform/users/@user.Id/roles"
                                  method="post"
                                  data-api-form="replace-user-roles"
                                  data-api-method="PUT">
                                <div class="dialog-heading">
                                    <div>
                                        <div class="eyebrow">ADMINISTRATION / USERS</div>
                                        <h2>Edit roles for @user.DisplayName</h2>
                                    </div>
                                    <button type="button" class="dialog-close" data-dialog-close aria-label="Close">Ã—</button>
                                </div>
                                <div class="form-error" role="alert" hidden></div>
                                <input type="hidden" name="Version" value="@user.Version" />
                                <fieldset>
                                    <legend>Role membership</legend>
                                    @foreach (var role in RoleOptions)
                                    {
                                        <label class="choice">
                                            <input name="RoleNames"
                                                   type="checkbox"
                                                   value="@role"
                                                   checked="@user.Roles.Contains(role)" />
                                            <span>@role</span>
                                        </label>
                                    }
                                </fieldset>
                                <label>
                                    <span>Reason</span>
                                    <textarea name="Reason" rows="3" required></textarea>
                                </label>
                                <div class="dialog-actions">
                                    <button type="button" data-dialog-close>Cancel</button>
                                    <button type="submit" class="primary-action">Save roles</button>
                                </div>
                            </form>
                        </dialog>
                        }
                        @if (CanOverridePermissions)
                        {
                        <dialog id="permission-@user.Id" class="admin-dialog compact-dialog">
                            <form action="/api/v1/platform/users/@user.Id/permission-overrides"
                                  method="post"
                                  data-api-form="create-permission-override">
                                <div class="dialog-heading">
                                    <div>
                                        <div class="eyebrow">ADMINISTRATION / PERMISSIONS</div>
                                        <h2>Add override for @user.DisplayName</h2>
                                    </div>
                                    <button type="button" class="dialog-close" data-dialog-close aria-label="Close">×</button>
                                </div>
                                <div class="form-error" role="alert" hidden></div>
                                <label>
                                    <span>Permission</span>
                                    <select name="PermissionKey" required>
                                        @foreach (var permission in PlatformPermissionCatalog.All)
                                        {
                                            <option value="@permission.Key">@permission.Key — @permission.Action</option>
                                        }
                                    </select>
                                </label>
                                <div class="form-grid">
                                    <label>
                                        <span>Effect</span>
                                        <select name="Effect" required>
                                            <option value="Allow">Allow</option>
                                            <option value="Deny">Deny</option>
                                        </select>
                                    </label>
                                    <label>
                                        <span>Expires</span>
                                        <input type="datetime-local" name="ExpiresAt" />
                                    </label>
                                </div>
                                <label>
                                    <span>Reason</span>
                                    <textarea name="Reason" rows="3" required></textarea>
                                </label>
                                <div class="dialog-actions">
                                    <button type="button" data-dialog-close>Cancel</button>
                                    <button type="submit" class="primary-action">Add override</button>
                                </div>
                            </form>
                        </dialog>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

<AuthorizeView Policy="platform.users.edit">
<dialog id="add-user-dialog" class="admin-dialog">
    <form action="/api/v1/platform/users" method="post" data-api-form="create-user">
        <div class="dialog-heading">
            <div>
                <div class="eyebrow">ADMINISTRATION / USERS</div>
                <h2>Add user</h2>
            </div>
            <button type="button" class="dialog-close" data-dialog-close aria-label="Close">×</button>
        </div>
        <div class="form-error" role="alert" hidden></div>
        <div class="form-grid">
            <label>
                <span>Display name</span>
                <input name="DisplayName" autocomplete="name" required />
            </label>
            <label>
                <span>Username</span>
                <input name="Username" autocomplete="username" required />
            </label>
            <label>
                <span>Email</span>
                <input name="Email" type="email" autocomplete="email" required />
            </label>
            <label>
                <span>Temporary password</span>
                <input name="Password" type="password" autocomplete="new-password" minlength="12" required />
            </label>
        </div>
        @if (CanEditRoles)
        {
        <fieldset>
            <legend>Roles</legend>
            <div class="choice-grid">
                @foreach (var role in RoleOptions)
                {
                    <label class="choice">
                        <input name="RoleNames" type="checkbox" value="@role" />
                        <span>@role</span>
                    </label>
                }
            </div>
        </fieldset>
        }
        <label>
            <span>Reason</span>
            <textarea name="Reason" rows="3" required
                      placeholder="Why is this account being created?"></textarea>
        </label>
        <div class="dialog-actions">
            <button type="button" data-dialog-close>Cancel</button>
            <button type="submit" class="primary-action">Create user</button>
        </div>
    </form>
</dialog>
</AuthorizeView>

@code {
    private UserRow[] UserRows { get; set; } = [];
    private string[] RoleOptions { get; set; } = [];
    private bool CanEditUsers { get; set; }
    private bool CanRevokeSessions { get; set; }
    private bool CanOverridePermissions { get; set; }
    private bool CanEditRoles { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var principal = (await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;
        CanEditUsers = (await AuthorizationService.AuthorizeAsync(
            principal, "platform.users.edit")).Succeeded;
        CanRevokeSessions = (await AuthorizationService.AuthorizeAsync(
            principal, "platform.sessions.revoke")).Succeeded;
        CanOverridePermissions = (await AuthorizationService.AuthorizeAsync(
            principal, "platform.permissions.override")).Succeeded;
        CanEditRoles = (await AuthorizationService.AuthorizeAsync(
            principal, "platform.roles.edit")).Succeeded;
        await using var db = await DbContextFactory.CreateDbContextAsync();
        var users = await db.Users
            .AsNoTracking()
            .OrderBy(x => x.DisplayName)
            .Select(x => new
            {
                x.Id,
                Username = x.UserName ?? string.Empty,
                x.DisplayName,
                x.IsEnabled,
                Version = x.ConcurrencyStamp ?? string.Empty
            })
            .ToArrayAsync();
        var roleMemberships = await (
            from userRole in db.UserRoles.AsNoTracking()
            join role in db.Roles.AsNoTracking() on userRole.RoleId equals role.Id
            orderby role.Name
            select new { userRole.UserId, RoleName = role.Name ?? string.Empty })
            .ToArrayAsync();
        var rolesByUser = roleMemberships
            .GroupBy(x => x.UserId)
            .ToDictionary(x => x.Key, x => x.Select(role => role.RoleName).ToArray());
        var systemRoleNames = (await db.Roles
            .AsNoTracking()
            .Where(x => x.IsSystemRole)
            .Select(x => x.Name ?? string.Empty)
            .ToArrayAsync())
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
        var overridesByUser = (await db.UserPermissionOverrides
                .AsNoTracking()
                .OrderBy(x => x.PermissionKey)
                .Select(x => new OverrideRow(
                    x.Id,
                    x.UserId,
                    x.PermissionKey,
                    x.IsAllowed,
                    x.ExpiresAt))
                .ToArrayAsync())
            .GroupBy(x => x.UserId)
            .ToDictionary(x => x.Key, x => x.ToArray());
        var lastSeenByUser = await db.Sessions
            .AsNoTracking()
            .GroupBy(x => x.UserId)
            .Select(x => new
            {
                UserId = x.Key,
                LastSeenAt = x.Max(session => session.LastSeenAt)
            })
            .ToDictionaryAsync(x => x.UserId, x => (DateTimeOffset?)x.LastSeenAt);
        RoleOptions = await db.Roles
            .AsNoTracking()
            .OrderBy(x => x.Name)
            .Select(x => x.Name ?? string.Empty)
            .ToArrayAsync();

        UserRows = users
            .Select(x => new UserRow(
                x.Id,
                x.Username,
                x.DisplayName,
                x.IsEnabled,
                x.Version,
                rolesByUser.GetValueOrDefault(x.Id, [])
                    .Any(systemRoleNames.Contains),
                lastSeenByUser.GetValueOrDefault(x.Id),
                rolesByUser.GetValueOrDefault(x.Id, []),
                overridesByUser.GetValueOrDefault(x.Id, [])))
            .ToArray();
    }

    private sealed record UserRow(
        Guid Id,
        string Username,
        string DisplayName,
        bool IsEnabled,
        string Version,
        bool HasSystemRole,
        DateTimeOffset? LastSeenAt,
        string[] Roles,
        OverrideRow[] Overrides);

    private sealed record OverrideRow(
        Guid Id,
        Guid UserId,
        string PermissionKey,
        bool IsAllowed,
        DateTimeOffset? ExpiresAt);
}
